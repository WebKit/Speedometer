{
    "name": "todomvc-backbone-complex",
    "version": "1.0.0",
    "description": "TodoMVC app written with backbone.",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=8.19.3"
    },
    "private": true,
    "scripts": {
        "build": "node scripts/build.mjs",
        "build:resources": "node ../../../../resources/shared/generate-resources.mjs dist",
        "postbuild": "npm run build:resources",
        "serve": "http-server ./dist -p 7002 -c-1 --cors"
    },
    "devDependencies": {
        "big-dom-generator": "file:../../big-dom-generator",
        "http-server": "^14.1.1",
        "todomvc-backbone": "file:../backbone"
    }
}
